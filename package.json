{
  "name": "roacm-blog",
  "version": "1.0.0",
  "description": "Automated testing for ROACM Jekyll blog theme",
  "scripts": {
    "prebuild:js": "mkdir -p assets/js/lib && cp node_modules/lunr/lunr.min.js assets/js/lib/",
    "build:js": "cat assets/js/lib/lunr.min.js assets/js/umami-tracker.js assets/js/code-blocks.js assets/js/reading-progress.js assets/js/back-to-top.js assets/js/lazy-loading.js assets/js/image-zoom-links.js assets/js/toc.js assets/js/search.js assets/js/mobile-menu.js assets/js/upcoming-talks.js | npx terser -o assets/js/bundle.min.js --compress --mangle --source-map",
    "build:css": "lightningcss --minify _site/assets/css/overrides.css -o _site/assets/css/overrides.css && lightningcss --minify _site/assets/css/style.css -o _site/assets/css/style.css && lightningcss --minify _site/assets/css/fonts.css -o _site/assets/css/fonts.css",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "npm run lint:css && npm run lint:js && npm run lint:html && npm run test:scripts",
    "test:scripts": "node --test .github/scripts/*.test.js",
    "test:e2e": "playwright test -c test-suite/configs/playwright.config.ts",
    "test:visual": "playwright test -c test-suite/configs/playwright.config.ts --grep @visual",
    "snapshots": "bash scripts/visual-snapshots.sh --project=chromium --project=firefox --project=webkit --update-snapshots --grep=@visual",
    "snapshots:verify": "bash scripts/visual-snapshots.sh --project=chromium --project=firefox --project=webkit --grep=@visual",
    "verify": "bash scripts/visual-snapshots.sh --project=chromium",
    "snapshots:targeted": "bash scripts/snapshots-targeted.sh",
    "snapshots:failed": "bash scripts/visual-snapshots.sh --project=chromium --project=firefox --project=webkit --update-snapshots --last-failed",
    "test:a11y": "playwright test -c test-suite/configs/playwright.config.ts --grep @a11y",
    "test:lighthouse": "lhci autorun --config=test-suite/configs/lighthouse.config.js",
    "preflight": "npm run test:unit && npm run test:e2e -- --project=chromium --project=firefox --project=webkit && npm run test:a11y && npm run test:lighthouse",
    "lint:css": "stylelint \"assets/css/**/*.css\" \"_sass/overrides/**/*.scss\" --config test-suite/configs/stylelint.config.json",
    "lint:js": "eslint \"assets/js/**/*.js\" --config test-suite/configs/eslint.config.mjs",
    "lint:html": "node test-suite/scripts/validate-html.js",
    "audit:css": "node scripts/audit-css.mjs",
    "audit:includes": "bash scripts/audit-includes.sh",
    "audit:images": "bash scripts/audit-images.sh",
    "audit:duplicates": "bash scripts/audit-duplicates.sh",
    "audit:dead-code": "npm run audit:css && npm run audit:includes && npm run audit:images && npm run audit:duplicates",
    "images:optimize": "node scripts/optimize-images.mjs",
    "images:transform": "node scripts/transform-images.mjs",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "lunr": "^2.3.9",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "gray-matter": "^4.0.3",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.7",
    "lightningcss-cli": "^1.32.0",
    "lint-staged": "^17.2.0",
    "prettier": "^3.8.4",
    "purgecss": "^8.0.0",
    "sharp": "^0.35.2",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "terser": "^5.48.0"
  },
  "lint-staged": {
    "*.css": [
      "stylelint --fix --allow-empty-input --config test-suite/configs/stylelint.config.json",
      "stylelint --allow-empty-input --config test-suite/configs/stylelint.config.json",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix --config test-suite/configs/eslint.config.mjs",
      "eslint --config test-suite/configs/eslint.config.mjs",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "tmp": "0.2.7"
  }
}
